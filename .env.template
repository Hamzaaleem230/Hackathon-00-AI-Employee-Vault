# AI Employee Vault - Environment Variables Template
# Copy this file to .env and fill in your actual secrets.
# DO NOT commit the .env file to Git.

# --- Email Service (watcher/email_service.py) ---
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=sender@example.com
NOTIFY_EMAIL=recipient@example.com

# --- Odoo Integration (mcp_servers/odoo_mcp.py) ---
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_odoo_database_name
ODOO_USERNAME=your_odoo_username
ODOO_PASSWORD=your_odoo_password

# --- Social Media APIs (mcp_servers/social_media_mcp.py) ---
FACEBOOK_API_KEY=your_facebook_api_key
FACEBOOK_API_SECRET=your_facebook_api_secret
INSTAGRAM_API_KEY=your_instagram_api_key
INSTAGRAM_API_SECRET=your_instagram_api_secret
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
LINKEDIN_API_KEY=your_linkedin_api_key
LINKEDIN_API_SECRET=your_linkedin_api_secret

# --- Other Configurations ---
VAULT_SYNC_REPO=your_git_repo_url_for_vault_sync
